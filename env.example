# ══════════════════════════════════════════════════════════════════════
#  OSINT Pipeline — Configuración
#  Copia este archivo a .env:   cp .env.example .env
#
#  ⚠  NUNCA subas .env a git. Está en .gitignore.
# ══════════════════════════════════════════════════════════════════════

# ── TARGET ─────────────────────────────────────────────────────────────
# Única variable obligatoria. Todo lo demás se deriva automáticamente:
#   • target_org      → nombre del org (parte antes del TLD)
#   • target_slug     → slug sin guiones (para nombres de archivo/bucket)
#   • target_variants → dominios alternativos a escanear
#   • bucket_variants → variantes de nombres de bucket S3/GCS/Azure
target_domain=bridgefundinggroupinc.com

# ── HuggingFace ────────────────────────────────────────────────────────
# Registro gratuito: https://huggingface.co/join
# Token en:         https://huggingface.co/settings/tokens  (tipo: Read)
# Activa los módulos NER (Módulo 9) y clasificación zero-shot (Módulo 10).
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Shodan ─────────────────────────────────────────────────────────────
# Registro gratuito: https://account.shodan.io/register
# API key en:       https://account.shodan.io/
# Plan free: 100 queries/mes. Sin key usa Shodan InternetDB (sin auth).
SHODAN_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Hunter.io ──────────────────────────────────────────────────────────
# Registro gratuito: https://hunter.io/users/sign_up
# API key en:       https://hunter.io/api-keys
# Plan free: 25 búsquedas/mes. Sin key usa Wayback CDX como fallback.
HUNTER_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── VirusTotal ─────────────────────────────────────────────────────────
# Registro gratuito: https://www.virustotal.com/gui/join-us
# API key en:       https://www.virustotal.com/gui/my-apikey
# Plan free: 500 req/día. Sin key solo se obtiene info básica pública.
VIRUSTOTAL_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── GitHub ─────────────────────────────────────────────────────────────
# Token en: https://github.com/settings/tokens  (sin scopes = solo acceso público)
# Sin token: rate limit 10 req/min. Con token: 30 req/min.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
